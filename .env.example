# Copy this file to .env before using docker compose.

# Shared
HOME=/home/your-user

# vLLM
HF_TOKEN=
VLLM_PORT=8000
VLLM_DTYPE=bfloat16
VLLM_API_KEY=local-dev-key

# NVIDIA NIM
NGC_API_KEY=
NIM_PORT=8000
NIM_IMAGE=nvcr.io/nim/nvidia/llama-nemotron-embed-vl-1b-v2:1.12.0

# FastAPI wrapper
WRAPPER_PORT=8010
BACKEND_BASE_URL=http://host.docker.internal:8000
BACKEND_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
BACKEND_API_KEY=
BACKEND_TIMEOUT_SECONDS=300
ALLOW_INPUT_TYPE_FALLBACK=true
